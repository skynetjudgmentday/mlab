cmake_minimum_required(VERSION 3.14)

add_executable(numkit_mide src/repl_bindings.cpp)
target_link_libraries(numkit_mide PRIVATE numkit::numkit)

if(EMSCRIPTEN)
    set_target_properties(numkit_mide PROPERTIES
        OUTPUT_NAME "numkit_mide"
        SUFFIX ".js"
        RUNTIME_OUTPUT_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/dist"
    )

    target_link_options(numkit_mide PRIVATE
        --bind
        "SHELL:-s MODULARIZE=1"
        "SHELL:-s EXPORT_NAME=createNumkitMideModule"
        "SHELL:-s ALLOW_MEMORY_GROWTH=1"
        "SHELL:-s INITIAL_MEMORY=67108864"
        "SHELL:-s STACK_SIZE=4194304"
        "SHELL:-s EXPORTED_RUNTIME_METHODS=[FS]"
        "SHELL:-s DISABLE_EXCEPTION_CATCHING=0"
        -O2
    )

    target_compile_options(numkit_mide PRIVATE
        -fexceptions
        -O2
    )

    set(DIST_DIR "${CMAKE_CURRENT_BINARY_DIR}/dist")

    # ── Copy WASM output into Vite public/ directory ──
    # Set NUMKIT_VITE_DIR to point to your repl-vite project root
    set(NUMKIT_VITE_DIR "${CMAKE_CURRENT_SOURCE_DIR}/repl-vite" CACHE PATH
        "Path to the Vite REPL project (for auto-copying WASM files)")

    add_custom_command(TARGET numkit_mide POST_BUILD
        COMMAND ${CMAKE_COMMAND} -E make_directory "${DIST_DIR}"
        # If Vite project exists, copy WASM files there too
        COMMAND ${CMAKE_COMMAND} -E echo "WASM build complete: ${DIST_DIR}/"
        COMMENT "Building WASM REPL..."
    )

    # Auto-copy to Vite public/ if the directory exists
    if(EXISTS "${NUMKIT_VITE_DIR}/public")
        add_custom_command(TARGET numkit_mide POST_BUILD
            COMMAND ${CMAKE_COMMAND} -E copy_if_different
                "${DIST_DIR}/numkit_mide.js"
                "${DIST_DIR}/numkit_mide.wasm"
                "${NUMKIT_VITE_DIR}/public/"
            COMMENT "Copying WASM files to Vite project: ${NUMKIT_VITE_DIR}/public/"
        )
    endif()

    # Legacy: also copy old web assets for standalone mode
    if(EXISTS "${CMAKE_CURRENT_SOURCE_DIR}/web")
        add_custom_command(TARGET numkit_mide POST_BUILD
            COMMAND ${CMAKE_COMMAND} -E copy_if_different
                "${CMAKE_CURRENT_SOURCE_DIR}/web/index.html"
                "${CMAKE_CURRENT_SOURCE_DIR}/web/repl.css"
                "${CMAKE_CURRENT_SOURCE_DIR}/web/repl.js"
                "${CMAKE_CURRENT_SOURCE_DIR}/web/terminal.js"
                "${CMAKE_CURRENT_SOURCE_DIR}/web/examples.js"
                "${DIST_DIR}/"
            COMMENT "Copying legacy web assets to dist/"
        )
    endif()

    add_custom_target(serve
        COMMAND ${CMAKE_COMMAND} -E echo "Open http://localhost:8080"
        COMMAND python3 -m http.server 8080 --directory "${DIST_DIR}"
        DEPENDS numkit_mide
        WORKING_DIRECTORY "${DIST_DIR}"
        COMMENT "Starting local dev server..."
    )

else()
    message(WARNING "repl/ is designed for Emscripten. Use: emcmake cmake .. -DNUMKIT_BUILD_REPL=ON")
endif()
